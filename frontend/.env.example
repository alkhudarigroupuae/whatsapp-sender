# Copy to .env.local for local dev (optional)

# Leave empty: Vite proxies /api → http://localhost:4000 (see vite.config.js)

# Production — call API directly (set in Vercel if NOT using proxy):
# VITE_API_BASE_URL=https://YOUR_API_ORIGIN

# Production — Vercel proxy: leave unset; set BACKEND_URL only in Vercel dashboard
# VITE_API_BASE_URL=

# Google sign-in (optional) — OAuth 2.0 Web client ID from Google Cloud Console
# Must match GOOGLE_CLIENT_ID on the backend
# VITE_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
